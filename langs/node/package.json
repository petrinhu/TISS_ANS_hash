{
  "name": "tiss-hash",
  "version": "0.1.0",
  "description": "Hash MD5 do epílogo XML TISS/ANS (Padrão TISS). Reverse-engineered, validado contra goldens reais privados + vetores sintéticos.",
  "type": "module",
  "main": "src/index.cjs",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.cjs"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js test/*.test.cjs",
    "lint": "eslint .",
    "coverage": "c8 --reporter=text --reporter=text-summary node --test test/*.test.js test/*.test.cjs",
    "audit:ci": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.0"
  },
  "keywords": [
    "tiss",
    "ans",
    "hash",
    "md5",
    "xml",
    "epilogo",
    "padrao-tiss",
    "saude-suplementar",
    "brasil",
    "healthcare"
  ],
  "author": "Petrus Silva Costa <petrinhu@yahoo.com.br>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/petrinhu/TISS_ANS_hash.git",
    "directory": "langs/node"
  },
  "homepage": "https://github.com/petrinhu/TISS_ANS_hash",
  "bugs": "https://github.com/petrinhu/TISS_ANS_hash/issues",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0"
  }
}
